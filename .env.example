# ============================================================================
#  SmartTrader environment template. Copy to `.env` and fill in real values.
#  `.env` is gitignored — NEVER commit real secrets.
# ============================================================================

# ---- Database ----
POSTGRES_USER=trader
POSTGRES_PASSWORD=change-me
POSTGRES_DB=smart_trading
DB_PORT=5471
DATABASE_URL=postgresql://trader:change-me@postgres:5432/smart_trading

# ---- Host ports ----
API_PORT=3001
ENGINE_PORT=8001
FRONTEND_PORT=5174

# ---- Secrets ----
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
OPENROUTER_API_KEY=your_openrouter_key_here
GEMINI_API_KEY=your_gemini_key_here

# ---- API auth ----
API_KEY=generate-a-strong-random-key
# Single-user app PIN (browser lock screen). Blank disables it.
APP_PIN=1234

# ---- Telegram alerts toggle ----
TELEGRAM_ENABLED=true

# ---- Market data / paper trading broker ----
# BROKER: dhan (default) | upstox.  DATA_SOURCE: auto | broker | yfinance.
BROKER=dhan
DATA_SOURCE=auto
DHAN_ACCESS_TOKEN=
DHAN_CLIENT_ID=
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_REDIRECT_URI=
UPSTOX_ACCESS_TOKEN=
