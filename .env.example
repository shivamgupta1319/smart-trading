# ============================================================================
#  SmartTrader environment template. Copy to `.env` and fill in real values.
#  `.env` is gitignored — NEVER commit real secrets.
# ============================================================================

# ---- Database ----
POSTGRES_USER=trader
POSTGRES_PASSWORD=change-me
POSTGRES_DB=smart_trading
DB_PORT=5471
DATABASE_URL=postgresql://trader:change-me@postgres:5432/smart_trading

# ---- Host ports ----
API_PORT=3001
ENGINE_PORT=8001
FRONTEND_PORT=5174

# ---- Secrets ----
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
OPENROUTER_API_KEY=your_openrouter_key_here
GEMINI_API_KEY=your_gemini_key_here

# ---- API auth ----
API_KEY=generate-a-strong-random-key
# Single-user app PIN (browser lock screen). Blank disables it.
APP_PIN=1234

# ---- Telegram alerts toggle ----
TELEGRAM_ENABLED=true

# ---- Risk / capital model (authentic paper-trading account) ----
# Account cash and per-trade risk. ROI is measured against INITIAL_CAPITAL.
INITIAL_CAPITAL=100000
RISK_PER_TRADE_PCT=2
# Buying-power multiple by hold type. Intraday (MIS) ~5×, delivery (CNC) 1×.
# Leverage only sets how much margin a position locks up — NOT the loss (the stop caps that).
LEVERAGE_INTRADAY=5
LEVERAGE_DELIVERY=1
# Max total open risk ("heat") as % of capital before new trades go SHADOW (3× the 2% rule).
MAX_HEAT_PCT=6
# A (stock×strategy) cell needs ≥ this many closed trades before its edge metrics are "reliable".
MIN_TRADES_FOR_CONFIDENCE=20

# ---- Historical-data fetch scheduler (profile: live) ----
# Runs a daily after-close fetch of every active stock so backtest history grows.
FETCH_RUN_HOUR_IST=16          # hour (IST) to run the daily fetch (after 15:30 close)
FETCH_RUN_MINUTE_IST=0
FETCH_TIMEFRAMES=1D,15m,5m
FETCH_ON_START=true            # also fetch once on container start (initial backfill)

# ---- Market data / paper trading broker ----
# BROKER: dhan (default) | upstox.  DATA_SOURCE: auto | broker | yfinance.
BROKER=dhan
DATA_SOURCE=auto
DHAN_ACCESS_TOKEN=
DHAN_CLIENT_ID=
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_REDIRECT_URI=
UPSTOX_ACCESS_TOKEN=
