// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model NseStock {
  id           Int      @id @default(autoincrement())
  symbol       String   @unique
  companyName  String
  sector       String?
  createdAt    DateTime @default(now())
}

model Stock {
  id           Int                  @id @default(autoincrement())
  symbol       String               @unique
  isActive     Boolean              @default(true)
  createdAt    DateTime             @default(now())

  historicalData      HistoricalData[]
  backtestReports     BacktestReport[]
  activeConfigurations ActiveConfiguration[]
  liveSignals         LiveSignal[]
  trades              Trade[]
}

model HistoricalData {
  id        Int      @id @default(autoincrement())
  stockId   Int
  timestamp DateTime
  open      Float
  high      Float
  low       Float
  close     Float
  volume    Float
  timeframe String   // "1D", "15m", "5m"

  stock Stock @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@unique([stockId, timestamp, timeframe])
  @@index([stockId, timeframe, timestamp])
}

model BacktestReport {
  id           Int      @id @default(autoincrement())
  stockId      Int
  strategyName String
  timeframe    String
  winRate      Float
  totalTrades  Int
  netProfit    Float
  maxDrawdown  Float
  roiPercentage Float
  createdAt    DateTime @default(now())

  stock Stock @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@index([stockId, strategyName])
}

model ActiveConfiguration {
  id           Int    @id @default(autoincrement())
  stockId      Int
  strategyName String
  timeframe    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  stock Stock @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@unique([stockId, strategyName])
}

model LiveSignal {
  id           Int      @id @default(autoincrement())
  stockId      Int
  strategyName String
  signalType   String   // "BUY" | "SELL"
  entryPrice   Float
  stopLoss     Float
  target       Float
  holdDuration String?  // "INTRADAY" | "SHORT_SWING" | "MID_SWING" | "LONG_POSITIONAL"
  timestamp    DateTime @default(now())
  status       String   @default("ACTIVE") // "ACTIVE" | "CLOSED"

  stock Stock @relation(fields: [stockId], references: [id], onDelete: Cascade)
  trade Trade?

  @@index([stockId, status])
}

model Trade {
  id            Int       @id @default(autoincrement())
  signalId      Int       @unique
  stockId       Int
  symbol        String
  strategyName  String
  signalType    String    // "BUY" | "SELL"
  holdDuration  String    // "INTRADAY" | "SHORT_SWING" | "MID_SWING" | "LONG_POSITIONAL"
  entryPrice    Float
  exitPrice     Float?
  stopLoss      Float
  target        Float
  quantity      Int       @default(1)
  capitalUsed   Float     @default(0) // Amount of capital allocated to this trade
  riskAmount    Float     @default(0) // Amount at risk (entry - SL) * quantity
  pnl           Float?
  pnlPercent    Float?
  outcome       String?   // "WIN" | "LOSS" | "BREAKEVEN"
  entryTime     DateTime
  exitTime      DateTime?
  status        String    @default("OPEN") // "OPEN" | "CLOSED"
  notes         String?
  originalStopLoss Float? // Original SL before any trailing adjustments
  trailingState String    @default("INITIAL") // "INITIAL" | "PHASE1" | "PHASE2" | "PHASE3" | "REVERSAL_EXIT"
  peakPrice     Float?    // Best favorable price reached during the trade
  realizedPnl   Float     @default(0) // PnL accumulated from partial exits
  remainingQty  Int       @default(1) // Remaining quantity after partials
  createdAt     DateTime  @default(now())

  signal        LiveSignal @relation(fields: [signalId], references: [id], onDelete: Cascade)
  stock         Stock      @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@index([stockId, status])
  @@index([status])
  @@index([strategyName])
}
